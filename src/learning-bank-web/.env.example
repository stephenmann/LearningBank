# Copy to .env.local and fill in the values.
# NEVER commit the actual secrets — this file is a template only.
# Full setup guide: docs/environment-setup.md

# NextAuth secret used to sign/encrypt session tokens.
# Generate with PowerShell or OpenSSL (see docs/environment-setup.md).
AUTH_SECRET=

# Google OAuth Web App credentials from Google Cloud Console.
# Redirect URI must include:
# http://localhost:3000/api/auth/callback/google
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# Microsoft Entra App Registration credentials.
# Redirect URI must include:
# http://localhost:3000/api/auth/callback/microsoft-entra-id
AZURE_AD_CLIENT_ID=
AZURE_AD_CLIENT_SECRET=

# Optional Azure tenant override for Microsoft Entra sign-in.
# Use "common" for personal + work/school accounts, or set your tenant GUID
# to restrict sign-in to a single tenant.
AZURE_AD_TENANT_ID=common

# Backend API base URL used by the web app.
# Keep /api/v1 suffix for the current API route group.
NEXT_PUBLIC_API_URL=http://localhost:5001/api/v1

# Public URL of the Next.js web app.
NEXTAUTH_URL=http://localhost:3000
